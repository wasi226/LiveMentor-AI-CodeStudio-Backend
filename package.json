{
  "name": "livementor-backend",
  "version": "1.0.0",
  "description": "Backend services for liveMentor AI CodeStudio",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "node build.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "deploy": "base44 deploy",
    "migrate": "node src/migrations/migrate.js",
    "seed": "node src/migrations/seed.js",
    "docs": "swagger-jsdoc -d swaggerDef.js src/routes/*.js -o docs/api.json"
  },
  "dependencies": {
    "@base44/sdk": "^0.8.20",
    "axios": "^1.4.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^9.3.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.3",
    "pino": "^8.14.1",
    "rate-limiter-flexible": "^2.4.2",
    "socket.io-client": "^4.8.3",
    "winston": "^3.9.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "eslint": "^8.43.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "education",
    "coding",
    "collaboration",
    "base44",
    "nodejs",
    "api"
  ],
  "author": "liveMentor Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livementor/ai-codestudio-backend.git"
  },
  "bugs": {
    "url": "https://github.com/livementor/ai-codestudio-backend/issues"
  },
  "homepage": "https://github.com/livementor/ai-codestudio-backend#readme"
}
