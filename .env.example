# ==============================================
# liveMentor AI CodeStudio - Backend Environment
# ==============================================

# Application Configuration
NODE_ENV=development
PORT=3001
APP_NAME=liveMentor AI CodeStudio Backend
APP_VERSION=1.0.0

# Base44 Backend-as-a-Service Configuration
BASE44_PROJECT_ID=your_base44_project_id_here
BASE44_API_KEY=your_base44_api_key_here
BASE44_REGION=us-east-1
BASE44_ENVIRONMENT=development

# Authentication & Security
JWT_SECRET=your_super_secure_jwt_secret_here_minimum_32_characters
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=true

# External API Keys

# Piston Code Execution API
# Free option: self-host Piston locally or on your server
# Public Piston access now requires authorization; use PISTON_API_TOKEN if provided
PISTON_API_URL=http://localhost:2000/api/v2/piston
PISTON_API_TOKEN=
PISTON_API_AUTH_HEADER=Authorization
PISTON_API_AUTH_SCHEME=Bearer
PISTON_REQUEST_TIMEOUT=15000
PISTON_COMPILE_TIMEOUT=10000
PISTON_RUN_TIMEOUT=5000
PISTON_RUN_MEMORY_LIMIT=134217728
PISTON_COMPILE_MEMORY_LIMIT=268435456

# OpenAI API (for AI Assistant)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Email Service (for notifications)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM_NAME=liveMentor AI CodeStudio
EMAIL_FROM_ADDRESS=noreply@livementor.com

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# File Storage
STORAGE_PROVIDER=base44
STORAGE_BUCKET=livementor-uploads
STORAGE_REGION=us-east-1
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,txt,py,js,java,cpp,ts,go,rs

# WebSocket Configuration
WS_PORT=3002
WS_PATH=/websocket
SOCKET_IO_PATH=/socket.io
WS_CORS_ORIGIN=http://localhost:5173
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000

# Analytics & Monitoring
ANALYTICS_ENABLED=true
MONITORING_ENABLED=true
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Performance Monitoring
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Database Configuration (if using additional databases)
POSTGRES_URL=postgresql://user:password@localhost:5432/livementor
MONGO_URL=mongodb://localhost:27017/livementor

# Feature Flags
ENABLE_CODE_EXECUTION=true
ENABLE_AI_ASSISTANT=true
ENABLE_REAL_TIME_COLLABORATION=true
ENABLE_VERSION_CONTROL=true
ENABLE_PERFORMANCE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEBSOCKETS=true
ENABLE_CACHING=true
ENABLE_FILE_UPLOADS=true

# Development Tools
ENABLE_SWAGGER_DOCS=true
SWAGGER_URL=/api-docs
ENABLE_DEBUG_LOGGING=true
ENABLE_REQUEST_LOGGING=true
ENABLE_CORS_LOGGING=false

# Testing Configuration
TEST_DATABASE_URL=base44_test_project
TEST_JWT_SECRET=test_jwt_secret_for_testing_only
TEST_TIMEOUT=30000

# Production Settings (uncomment for production)
# NODE_ENV=production
# LOG_LEVEL=warn
# ENABLE_DEBUG_LOGGING=false
# ENABLE_REQUEST_LOGGING=false
# RATE_LIMIT_MAX_REQUESTS=1000
# JWT_EXPIRES_IN=1h